# This is coming from the example in the lectures. Monte Carlo Lecture slide 66
gibbs <- function(X0, p0, N0, m, iter){
# X0, p0, N0 are the initial values of X, p, N
# m is the cut-off point to remove burn-in values
# iter is the number of iterations generated. Must be bigger than m
if (m >= iter){
stop("Bigger value of m and iter")
}
# We are constructing a matrix with 3 columns (X, p, N)
simvals <- matrix(0, nrow = iter+1, ncol = 3)
simvals[1,] <- c(X0, p0, N0)
for (i in 2:(iter+1)){
xval <- rbinom(1, simvals[i-1, 3], simvals[i-1, 2])
pval <- rbeta(1, xval + 2, simvals[i-1,3] - xval + 4)
Nval <- rpois(1, 16*(1-pval)) + xval
simvals[i,] <- c(xval, pval, Nval)
}
simvals <- simvals[-(1:(m+1)),]
simvals <- as.data.frame(simvals)
colnames(simvals) <- c("X", "p", "N")
return(simvals)
}
set.seed(456)
iter <- 1000
m <- 100
gibbssample <- gibbs(8, 0.5, 15, m, iter)
table(gibbssample$N)/iter
table(gibbssample$X)/iter
plot(density(gibbssample$p))
plot(sort(unique(gibbssample$X)), as.numeric(table(gibbssample$X)/iter), type = 'h', lwd=5)
## Using Rao-Blackwell Theorem
rb <- 1/nrow(gibbssample) * sum(gibbssample$N * gibbssample$p)
varrb <- var(gibbssample$N * gibbssample$p)/nrow(gibbssample)
dim(gibbssample)
colMeans(gibbssample)
